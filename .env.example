# ============================================================
#  Research Bot Army — Secrets & API Keys
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# ------ REQUIRED ------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------ OPTIONAL: Better news coverage ------
# Get a free key at https://newsapi.org (100 req/day free)
NEWS_API_KEY=

# ------ OPTIONAL: Better review/search results ------
# Get a key at https://serpapi.com (100 free searches/month)
SERP_API_KEY=

# ------ OPTIONAL: Telegram delivery ------
# 1. Message @BotFather on Telegram to create a bot → get the token
# 2. Start a chat with your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------ OPTIONAL: Slack delivery ------
# Create an Incoming Webhook at https://api.slack.com/apps
SLACK_WEBHOOK_URL=

# ------ OPTIONAL: Email delivery ------
# For Gmail, use an App Password (Google Account → Security → App Passwords)
EMAIL_ADDRESS=
EMAIL_PASSWORD=
